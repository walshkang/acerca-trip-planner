# Copy to `.env.local` and fill in values. Next.js loads `.env.local` for local dev.

# --- Routing preview (Plan mode travel times) ---
# Without a working provider, POST /api/lists/[id]/routing/preview returns 501
# with status "provider_unavailable" (expected until configured).
#
# Use OSRM for local/dev (public demo server — rate limits apply):
#   ROUTING_PROVIDER=osrm
#   OSRM_BASE_URL=https://router.project-osrm.org
#
# Or run your own OSRM and point OSRM_BASE_URL at its base (no trailing slash on /route path).
ROUTING_PROVIDER=
OSRM_BASE_URL=

# --- Optional beta gate (shared deploy / friends testing) ---
# When set, all app pages and /api/* (except /api/beta-unlock POST and /auth/*) require
# a signed cookie obtained via POST /api/beta-unlock. Keeps casual traffic off Google Places.
# Cookie signing key is derived from this password (HMAC); no separate secret required.
# To rotate everyone off without changing the password, you’d add a dedicated signing secret later.
# Use double quotes so spaces or # in the password don’t break parsing, e.g.:
# BETA_ACCESS_PASSWORD="test"
BETA_ACCESS_PASSWORD=
