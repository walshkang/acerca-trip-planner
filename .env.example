# Copy to `.env.local` and fill in values. Next.js loads `.env.local` for local dev.

# --- Routing preview (Plan mode travel times) ---
# Without a working provider, POST /api/lists/[id]/routing/preview returns 501
# with status "provider_unavailable" (expected until configured).
#
# Use OSRM for local/dev (public demo server — rate limits apply):
#   ROUTING_PROVIDER=osrm
#   OSRM_BASE_URL=https://router.project-osrm.org
#
# Or run your own OSRM and point OSRM_BASE_URL at its base (no trailing slash on /route path).
ROUTING_PROVIDER=
OSRM_BASE_URL=
